# Anthropic API key (required for Stage 1 conversion runs)
ANTHROPIC_API_KEY=sk-ant-...

# Default model (overridable per run with --model)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Absolute path to the Stanford POS tagger model used by Paska's Java step.
# Download english-left3words-distsim.tagger from
# https://nlp.stanford.edu/software/tagger.shtml and place it under models/.
PASKA_POS_TAGGER_PATH=/absolute/path/to/RQ1ConvertToRimay/models/english-left3words-distsim.tagger
