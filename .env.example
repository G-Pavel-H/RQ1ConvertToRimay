# Copy to .env and fill in.

# Anthropic API key for the LLM conversion step (Stage 1).
ANTHROPIC_API_KEY=sk-ant-...

# Default model. Overridable via --model on run_conversion.py.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Absolute path to the Stanford POS tagger used by the Paska jar.
# Download english-left3words-distsim.tagger from
# https://nlp.stanford.edu/software/tagger.shtml and point this at it.
PASKA_POS_TAGGER_PATH=/absolute/path/to/models/english-left3words-distsim.tagger
